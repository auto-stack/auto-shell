# Rust build artifacts — each workspace (ash/, ash-gui/...) has its own target/
/target/
**/target/

# Binaries / build output
*.exe
*.pdb

# Editor / OS cruft
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Note: Cargo.lock IS committed — these are binary crates (ash, ash-gui),
# where lockfiles should be tracked.
# Exception: ash-core/Cargo.lock is NOT tracked — ash-core is consumed as
# a path dependency (a library), so the lockfile is a build-time artifact.
/ash-core/Cargo.lock

# Local scratch/scratch files for manual testing
**/tmp/
